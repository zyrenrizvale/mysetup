{
  "name": "tiktok-live-api-sdk",
  "version": "0.4.0-beta1",
  "description": "Node.js module for interacting with the Euler Stream TikTok LIVE API.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/EulerStream/Euler-Api-Sdk"
  },
  "keywords": [
    "tiktok",
    "tiktok live",
    "tiktok.com",
    "live",
    "stream",
    "livestream",
    "chat",
    "connector",
    "api",
    "webcast",
    "tracker",
    "scraper",
    "websocket",
    "bot",
    "broadcast",
    "reader"
  ],
  "author": "eulerstream",
  "license": "MIT",
  "homepage": "https://github.com/eulerstream/EulerApiSdk",
  "dependencies": {
    "axios": "^1.9.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.17.0",
    "@babel/core": "^7.17.2",
    "@babel/preset-env": "^7.16.11",
    "@types/node": "^22.15.3",
    "dotenv": "^16.5.0",
    "prettier": "2.5.1",
    "readline": "^1.3.0",
    "tsdown": "^0.21.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "generate": "mkdir -p build && wget -O ./build/openapi.json https://api.eulerstream.com/dashboard/openapi && npx @openapitools/openapi-generator-cli generate -i ./build/openapi.json -g typescript-axios -o ./src/sdk && tsx ./scripts/render-template.ts",
    "build": "tsdown",
    "test": "tsx ./test/basic.test.ts",
    "format": "prettier --write src/**/*.js"
  }
}